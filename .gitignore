# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# src/assets/data/*

# Archive data files (large files)
like-twitter-*.js
src/content/archive/archive-likes-enriched.json

# SQLite transient files (data/likes.db 本体はコミットする)
*.db-shm
*.db-wal
*.db-journal

# 検索アセット (SQLite から build-search-assets で再生成、pnpm build の先頭で自動)
/public/data/

# Claude Code settings (ディレクトリ配下の各エントリを除外しつつ agents/ と commands/ だけ通す)
.claude/*
!.claude/agents/
!.claude/commands/

# Podcast 生成物
# - mp3 は外部 storage (R2 / S3 など) 移行検討中。当面 gitignore で repo を肥らせない
# - transcript JSON (.script.json) は軽いので commit してアーカイブ
# - BGM (public/podcasts/bgm/) はユーザー提供の長期 asset、commit する
/public/podcasts/*.mp3
/data/podcasts/
/data/podcast-link-cache.json
